# ============================================
# ops-report-ai — .gitignore
# ============================================

# Dependencias
node_modules/
.pnp
.pnp.js

# Build
dist/
build/
*.js.map

# Variables de entorno — NUNCA al repositorio
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Cobertura de tests
coverage/
*.lcov
.nyc_output/

# Cache
.npm
.eslintcache
.cache/
.parcel-cache/

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# IDEs y editores
.idea/
.vscode/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Archivos de ingesta locales — datos reales nunca al repo
uploads/
data/raw/
data/processed/
*.xlsx
*.csv
!test/**/*.xlsx
!test/**/*.csv

# Archivos temporales
tmp/
temp/